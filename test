    };

    function setLanguage(lang) {
      document.documentElement.lang = lang;
      document.getElementById("title").textContent = translations[lang].title;
      document.getElementById("author").textContent = translations[lang].author;
      document.getElementById("summary").textContent = translations[lang].summary;
      document.getElementById("chaptersTitle").textContent = translations[lang].chaptersTitle;
      document.getElementById("ch1").textContent = translations[lang].ch1;
      document.getElementById("ch2").textContent = translations[lang].ch2;
      document.getElementById("ch3").textContent = translations[lang].ch3;
      document.getElementById("ch4").textContent = translations[lang].ch4;
